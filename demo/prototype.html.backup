                </div>
                
                <!-- 渠道效果 -->
                <div class="rich-card rounded-xl p-4">
                    <h4 class="font-semibold text-slate-800 text-sm mb-4">本周渠道效果</h4>
                    <div class="space-y-3">
                        <div>
                            <div class="flex items-center justify-between text-sm mb-1">
                                <span class="text-slate-600">数据外联</span>
                                <span class="font-semibold text-slate-800">45%</span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill gradient-accent" style="width: 45%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex items-center justify-between text-sm mb-1">
                                <span class="text-slate-600">邮件营销</span>
                                <span class="font-semibold text-slate-800">32%</span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill gradient-success" style="width: 32%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex items-center justify-between text-sm mb-1">
                                <span class="text-slate-600">LinkedIn社媒</span>
                                <span class="font-semibold text-slate-800">18%</span>
                            </div>
                            <div class="progress-bar">
                                <div class="progress-fill bg-pink-500" style="width: 18%"></div>
                            </div>
                        </div>
                        <div>
                            <div class="flex items-center justify-between text-sm mb-1">
                                <span class="text-slate-600">SEO自然流量</span>
                                <span class="font-semibold text-slate-800">5%</span>
                            </div>
                            <div class="progress-bar">
