<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DealClaw 获客师 - 外贸B2B专属AI数字员工</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+SC:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'Noto Sans SC', 'system-ui', 'sans-serif'],
                    },
                    colors: {
                        primary: '#0F172A',
                        secondary: '#1E293B',
                        accent: '#3B82F6',
                        'accent-light': '#60A5FA',
                        success: '#10B981',
                        warning: '#F59E0B',
                        danger: '#EF4444',
                        'bg-primary': '#F8FAFC',
                        'bg-secondary': '#FFFFFF',
                        'bg-tertiary': '#F1F5F9',
                    }
                }
            }
        }
    </script>
    <style>
        * { scrollbar-width: thin; scrollbar-color: #CBD5E1 #F1F5F9; }
        *::-webkit-scrollbar { width: 6px; height: 6px; }
        *::-webkit-scrollbar-track { background: #F1F5F9; }
        *::-webkit-scrollbar-thumb { background: #CBD5E1; border-radius: 3px; }
        *::-webkit-scrollbar-thumb:hover { background: #94A3B8; }
        
        .fade-in { animation: fadeIn 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
        @keyframes fadeIn { 
            from { opacity: 0; transform: translateY(12px) scale(0.98); } 
            to { opacity: 1; transform: translateY(0) scale(1); } 
        }
        
        .slide-in-right { animation: slideInRight 0.3s ease; }
        @keyframes slideInRight { 
            from { opacity: 0; transform: translateX(20px); } 
            to { opacity: 1; transform: translateX(0); } 
        }
        
        .pulse-soft { animation: pulseSoft 2s ease-in-out infinite; }
        @keyframes pulseSoft { 0%, 100% { opacity: 1; } 50% { opacity: 0.6; } }
        
        .typing-dot { animation: typingDot 1.4s infinite; }
        .typing-dot:nth-child(2) { animation-delay: 0.2s; }
        .typing-dot:nth-child(3) { animation-delay: 0.4s; }
        @keyframes typingDot { 
            0%, 60%, 100% { transform: translateY(0); } 
            30% { transform: translateY(-6px); } 
        }
        
        .card-hover { transition: all 0.2s ease; }
        .card-hover:hover { transform: translateY(-2px); box-shadow: 0 12px 24px -8px rgba(0,0,0,0.12); }
        
        .gradient-bg { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); }
        .gradient-accent { background: linear-gradient(135deg, #3B82F6 0%, #8B5CF6 100%); }
        .gradient-success { background: linear-gradient(135deg, #10B981 0%, #059669 100%); }
        
        .glass-effect { background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(12px); }
        
        .message-bubble { position: relative; }
        .message-bubble::before {
            content: '';
            position: absolute;
            left: -6px;
            top: 12px;
            width: 12px;
            height: 12px;
            background: inherit;
            transform: rotate(45deg);
        }
        
        .rich-card { 
            background: linear-gradient(145deg, #ffffff 0%, #f8fafc 100%);
            border: 1px solid rgba(226, 232, 240, 0.8);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05), 0 2px 4px -1px rgba(0, 0, 0, 0.03);
        }
        
        .agent-avatar { 
            background: linear-gradient(135deg, #3B82F6 0%, #6366F1 100%);
            box-shadow: 0 4px 12px rgba(59, 130, 246, 0.4);
        }
        
        .status-dot { 
            width: 8px; 
            height: 8px; 
            border-radius: 50%; 
            display: inline-block;
            margin-right: 6px;
        }
        .status-active { background: #10B981; box-shadow: 0 0 8px #10B981; }
        .status-busy { background: #F59E0B; box-shadow: 0 0 8px #F59E0B; }
        .status-idle { background: #94A3B8; }
        
        .progress-bar { 
            height: 6px; 
            background: #E2E8F0; 
            border-radius: 3px; 
            overflow: hidden;
        }
        .progress-fill { 
            height: 100%; 
            border-radius: 3px; 
            transition: width 0.6s ease;
        }
        
        .score-high { background: linear-gradient(135deg, #10B981 0%, #059669 100%); }
        .score-medium { background: linear-gradient(135deg, #F59E0B 0%, #D97706 100%); }
        .score-low { background: linear-gradient(135deg, #EF4444 0%, #DC2626 100%); }
    </style>
</head>
<body class="bg-bg-primary text-slate-800 font-sans antialiased">
    <!-- 主布局容器 -->
    <div class="flex h-screen overflow-hidden">
        
        <!-- 左侧导航栏 -->
        <aside class="w-64 bg-white border-r border-slate-200 flex flex-col z-20 shadow-sm">
            <!-- Logo区域 -->
            <div class="p-5 border-b border-slate-100">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-xl gradient-accent flex items-center justify-center">
                        <i data-lucide="claw" class="w-6 h-6 text-white"></i>
                    </div>
                    <div>
                        <h1 class="font-bold text-lg text-primary">DealClaw</h1>
                        <p class="text-xs text-slate-500">获客师数字员工</p>
                    </div>
                </div>
                <div class="mt-3 flex items-center gap-2 text-xs text-slate-500">
                    <span class="status-dot status-active"></span>
                    <span>AI获客师在线</span>
                </div>
            </div>
            
            <!-- 导航菜单 -->
            <nav class="flex-1 overflow-y-auto p-3 space-y-1">
                <button onclick="switchView('chat')" id="nav-chat" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-accent bg-blue-50 transition-all">
                    <i data-lucide="message-square" class="w-5 h-5"></i>
                    <span>获客对话</span>
                    <span class="ml-auto bg-accent text-white text-xs px-2 py-0.5 rounded-full">新</span>
                </button>
                
                <button onclick="switchView('tasks')" id="nav-tasks" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-slate-600 hover:bg-slate-50 transition-all">
                    <i data-lucide="zap" class="w-5 h-5"></i>
                    <span>获客任务</span>
                    <span class="ml-auto bg-slate-200 text-slate-600 text-xs px-2 py-0.5 rounded-full">3</span>
                </button>
                
                <button onclick="switchView('leads')" id="nav-leads" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-slate-600 hover:bg-slate-50 transition-all">
                    <i data-lucide="users" class="w-5 h-5"></i>
                    <span>线索中心</span>
                    <span class="ml-auto bg-red-500 text-white text-xs px-2 py-0.5 rounded-full animate-pulse">5</span>
                </button>
                
                <button onclick="switchView('content')" id="nav-content" class="nav-item w-full flex items-center gap-3 px-4 py-3 rounded-xl text-sm font-medium text-slate-600 hover:bg-slate-50 transition-all">
                    <i data-lucide="file-text" class="w-5 h-5"></i>
                    <span>内容中心</span>
                    <span class="ml-auto bg-slate-200 text-slate-600 text-xs px-2 py-0.5 rounded-full">SEO</span>
                </button>
                
                <div class="pt-4 pb-2 px-4 text-xs font-semibold text-slate-400 uppercase tracking-wider">Agent团队</div>
                
                <button class="w-full flex items-center gap-3 px-4 py-2 rounded-xl text-sm text-slate-600 hover:bg-slate-50 transition-all">
                    <div class="w-6 h-6 rounded-lg bg-indigo-100 flex items-center justify-center">
                        <i data-lucide="search" class="w-3.5 h-3.5 text-indigo-600"></i>
                    </div>
                    <span>数据外联Agent</span>
                    <span class="status-dot status-active ml-auto"></span>
                </button>
                
                <button class="w-full flex items-center gap-3 px-4 py-2 rounded-xl text-sm text-slate-600 hover:bg-slate-50 transition-all">
                    <div class="w-6 h-6 rounded-lg bg-emerald-100 flex items-center justify-center">
                        <i data-lucide="globe" class="w-3.5 h-3.5 text-emerald-600"></i>
                    </div>
                    <span>SEO Agent</span>
                    <span class="status-dot status-active ml-auto"></span>
                </button>
                
                <button class="w-full flex items-center gap-3 px-4 py-2 rounded-xl text-sm text-slate-600 hover:bg-slate-50 transition-all">
                    <div class="w-6 h-6 rounded-lg bg-amber-100 flex items-center justify-center">
                        <i data-lucide="mail" class="w-3.5 h-3.5 text-amber-600"></i>
                    </div>
                    <span>Email Agent</span>
                    <span class="status-dot status-busy ml-auto"></span>
                </button>
                
                <button class="w-full flex items-center gap-3 px-4 py-2 rounded-xl text-sm text-slate-600 hover:bg-slate-50 transition-all">
                    <div class="w-6 h-6 rounded-lg bg-pink-100 flex items-center justify-center">
                        <i data-lucide="linkedin" class="w-3.5 h-3.5 text-pink-600"></i>
                    </div>
                    <span>社媒Agent</span>
                    <span class="status-dot status-active ml-auto"></span>
                </button>
            </nav>
            
            <!-- 用户信息 -->
            <div class="p-4 border-t border-slate-100">
                <div class="flex items-center gap-3">
                    <div class="relative">
                        <img src="https://api.dicebear.com/7.x/avataaars/svg?seed=manager" class="w-10 h-10 rounded-full bg-slate-100 border-2 border-white shadow-sm">
                        <div class="absolute -bottom-0.5 -right-0.5 w-3.5 h-3.5 bg-green-500 rounded-full border-2 border-white"></div>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="text-sm font-semibold text-slate-800 truncate">张经理</p>
                        <p class="text-xs text-slate-500 truncate">外贸业务部</p>
                    </div>
                    <button class="p-2 hover:bg-slate-100 rounded-lg transition-colors">
                        <i data-lucide="settings" class="w-4 h-4 text-slate-400"></i>
                    </button>
                </div>
            </div>
        </aside>
        
        <!-- 中间主区域 - 对话区 -->
        <main id="main-chat" class="flex-1 flex flex-col bg-gradient-to-br from-slate-50 to-blue-50/30">
            <!-- 顶部栏 -->
            <header class="h-16 bg-white/80 backdrop-blur-md border-b border-slate-200 flex items-center justify-between px-6 z-10">
                <div class="flex items-center gap-4">
                    <div class="flex items-center gap-2">
                        <span class="text-lg font-semibold text-slate-800">获客师</span>
                        <span class="px-2 py-0.5 bg-blue-100 text-blue-700 text-xs rounded-full font-medium">AI数字员工</span>
                    </div>
                    <div class="h-4 w-px bg-slate-200"></div>
                    <div class="flex items-center gap-2 text-sm text-slate-500">
                        <i data-lucide="database" class="w-4 h-4"></i>
                        <span>数据外联引擎就绪</span>
                        <span class="text-slate-300">|</span>
                        <span class="text-emerald-600 font-medium">3亿+企业库</span>
                    </div>
                </div>
                <div class="flex items-center gap-3">
                    <button onclick="showDataPanel()" class="flex items-center gap-2 px-4 py-2 bg-white border border-slate-200 rounded-lg text-sm font-medium text-slate-600 hover:border-accent hover:text-accent transition-all">
                        <i data-lucide="bar-chart-2" class="w-4 h-4"></i>
                        <span>实时数据</span>
                    </button>
                    <button class="p-2 hover:bg-slate-100 rounded-lg transition-colors">
                        <i data-lucide="help-circle" class="w-5 h-5 text-slate-400"></i>
                    </button>
                </div>
            </header>
            
            <!-- 对话内容区 -->
            <div id="chat-container" class="flex-1 overflow-y-auto p-6 space-y-6">
                <!-- 欢迎消息 -->
                <div class="flex gap-4 fade-in">
                    <div class="w-10 h-10 rounded-2xl agent-avatar flex items-center justify-center flex-shrink-0">
                        <i data-lucide="bot" class="w-6 h-6 text-white"></i>
                    </div>
                    <div class="flex-1 max-w-3xl">
                        <div class="bg-white rounded-2xl rounded-tl-sm p-5 shadow-sm border border-slate-100 message-bubble">
                            <p class="text-slate-700 leading-relaxed">您好！我是您的专属获客师 🤖</p>
                            <p class="text-slate-700 leading-relaxed mt-2">我已连接<span class="font-semibold text-accent">3亿+全球企业数据库</span>和<span class="font-semibold text-emerald-600">100亿条海关交易数据</span>，可以通过对话帮您：</p>
                            <ul class="mt-3 space-y-1.5 text-slate-600">
                                <li class="flex items-center gap-2"><i data-lucide="check-circle-2" class="w-4 h-4 text-emerald-500"></i>精准定位目标客户</li>
                                <li class="flex items-center gap-2"><i data-lucide="check-circle-2" class="w-4 h-4 text-emerald-500"></i>自动挖掘决策人联系方式</li>
                                <li class="flex items-center gap-2"><i data-lucide="check-circle-2" class="w-4 h-4 text-emerald-500"></i>AI生成个性化触达内容</li>
                                <li class="flex items-center gap-2"><i data-lucide="check-circle-2" class="w-4 h-4 text-emerald-500"></i>多渠道自动外联（邮件/LinkedIn/WhatsApp）</li>
                            </ul>
                        </div>
                        <div class="flex gap-2 mt-3">
                            <button onclick="quickStart('美国户外用品批发商')" class="px-4 py-2 bg-white border border-slate-200 rounded-full text-sm text-slate-600 hover:border-accent hover:text-accent transition-all">
                                💡 找美国户外用品批发商
                            </button>
                            <button onclick="quickStart('欧洲电子产品进口商')" class="px-4 py-2 bg-white border border-slate-200 rounded-full text-sm text-slate-600 hover:border-accent hover:text-accent transition-all">
                                💡 欧洲电子产品进口商
                            </button>
                        </div>
                    </div>
                </div>
                
                <!-- 动态消息将在这里插入 -->
            </div>
            
            <!-- 输入区域 -->
            <div class="p-4 bg-white/80 backdrop-blur-md border-t border-slate-200">
                <div class="max-w-4xl mx-auto">
                    <div class="flex items-end gap-3 bg-slate-50 rounded-2xl p-2 border border-slate-200 focus-within:border-accent focus-within:ring-4 focus-within:ring-blue-100 transition-all">
                        <button class="p-3 hover:bg-slate-200 rounded-xl transition-colors">
                            <i data-lucide="plus" class="w-5 h-5 text-slate-400"></i>
                        </button>
                        <textarea id="chat-input" rows="1" placeholder="描述您的目标客户，例如：帮我找美国做户外用品的批发商，年采购额100万美元以上..." 
                            class="flex-1 bg-transparent border-0 resize-none py-3 px-2 text-slate-700 placeholder:text-slate-400 focus:outline-none max-h-32"
                            onkeydown="handleKeyDown(event)"></textarea>
                        <div class="flex items-center gap-1 pb-1">
                            <button class="p-2 hover:bg-slate-200 rounded-xl transition-colors">
                                <i data-lucide="mic" class="w-5 h-5 text-slate-400"></i>
                            </button>
                            <button onclick="sendMessage()" class="p-3 bg-accent hover:bg-accent/90 rounded-xl text-white shadow-lg shadow-blue-200 transition-all hover:scale-105">
                                <i data-lucide="send" class="w-5 h-5"></i>
                            </button>
                        </div>
                    </div>
                    <div class="flex items-center justify-center gap-4 mt-2 text-xs text-slate-400">
                        <span class="flex items-center gap-1"><i data-lucide="shield-check" class="w-3 h-3"></i> GDPR合规</span>
                        <span class="flex items-center gap-1"><i data-lucide="database" class="w-3 h-3"></i> 数据来源合法</span>
                        <span class="flex items-center gap-1"><i data-lucide="lock" class="w-3 h-3"></i> 企业级加密</span>
                    </div>
                </div>
            </div>
        </main>
        
        <!-- 右侧上下文面板 -->
        <aside id="right-panel" class="w-96 bg-white border-l border-slate-200 flex flex-col z-20">
            <!-- 面板头部 -->
            <div class="p-5 border-b border-slate-100">
                <div class="flex items-center justify-between">
                    <h3 class="font-semibold text-slate-800">实时获客数据</h3>
                    <button class="p-1.5 hover:bg-slate-100 rounded-lg transition-colors">
                        <i data-lucide="maximize-2" class="w-4 h-4 text-slate-400"></i>
                    </button>
                </div>
            </div>
            
            <!-- 数据内容 -->
            <div class="flex-1 overflow-y-auto p-5 space-y-6">
                <!-- 核心指标卡片 -->
                <div class="grid grid-cols-2 gap-3">
                    <div class="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl p-4 border border-blue-100">
                        <div class="flex items-center gap-2 text-blue-600 text-xs font-medium mb-1">
                            <i data-lucide="users" class="w-3.5 h-3.5"></i>
                            今日新线索
                        </div>
                        <div class="text-2xl font-bold text-slate-800" id="stat-leads">12</div>
                        <div class="text-xs text-emerald-600 flex items-center gap-1 mt-1">
                            <i data-lucide="trending-up" class="w-3 h-3"></i> +23%
                        </div>
                    </div>
                    <div class="bg-gradient-to-br from-emerald-50 to-teal-50 rounded-xl p-4 border border-emerald-100">
                        <div class="flex items-center gap-2 text-emerald-600 text-xs font-medium mb-1">
                            <i data-lucide="target" class="w-3.5 h-3.5"></i>
                            高意向线索
                        </div>
                        <div class="text-2xl font-bold text-slate-800" id="stat-hot">5</div>
                        <div class="text-xs text-emerald-600 flex items-center gap-1 mt-1">
                            <i data-lucide="flame" class="w-3 h-3"></i> 立即跟进
                        </div>
                    </div>
                </div>
                
                <!-- 获客任务进度 -->
                <div class="rich-card rounded-xl p-4">
                    <div class="flex items-center justify-between mb-4">
                        <h4 class="font-semibold text-slate-800 text-sm">活跃获客任务</h4>
                        <span class="text-xs text-slate-500">3个进行中</span>
                    </div>
                    
                    <div class="space-y-4">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-lg bg-blue-100 flex items-center justify-center flex-shrink-0">
                                <i data-lucide="search" class="w-5 h-5 text-blue-600"></i>
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center justify-between">
                                    <p class="text-sm font-medium text-slate-700 truncate">美国户外用品批发商</p>
                                    <span class="text-xs text-blue-600 font-medium">68%</span>
                                </div>
                                <div class="progress-bar mt-2">
                                    <div class="progress-fill gradient-accent" style="width: 68%"></div>
                                </div>
                                <p class="text-xs text-slate-500 mt-1">数据外联Agent正在挖掘决策人...</p>
                            </div>
                        </div>
                        
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-lg bg-emerald-100 flex items-center justify-center flex-shrink-0">
                                <i data-lucide="globe" class="w-5 h-5 text-emerald-600"></i>
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center justify-between">
                                    <p class="text-sm font-medium text-slate-700 truncate">欧洲电子产品SEO优化</p>
                                    <span class="text-xs text-emerald-600 font-medium">42%</span>
                                </div>
                                <div class="progress-bar mt-2">
                                    <div class="progress-fill gradient-success" style="width: 42%"></div>
                                </div>
                                <p class="text-xs text-slate-500 mt-1">SEO Agent已发布8篇文章</p>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Agent状态 -->
                <div class="rich-card rounded-xl p-4">
                    <h4 class="font-semibold text-slate-800 text-sm mb-4">Agent工作状态</h4>
                    <div class="space-y-3">
                        <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center">
                                    <i data-lucide="search" class="w-4 h-4 text-indigo-600"></i>
                                </div>
                                <div>
                                    <p class="text-sm font-medium text-slate-700">数据外联Agent</p>
                                    <p class="text-xs text-slate-500">正在挖掘决策人联系方式</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="status-dot status-active"></span>
                                <span class="text-xs text-emerald-600">运行中</span>
                            </div>
                        </div>
                        
                        <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-lg bg-emerald-100 flex items-center justify-center">
                                    <i data-lucide="globe" class="w-4 h-4 text-emerald-600"></i>
                                </div>
                                <div>
                                    <p class="text-sm font-medium text-slate-700">SEO Agent</p>
                                    <p class="text-xs text-slate-500">优化关键词排名</p>
                                </div>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="status-dot status-active"></span>
                                <span class="text-xs text-emerald-600">运行中</span>
                            </div>
                        </div>
                        
                        <div class="flex items-center justify-between p-3 bg-slate-50 rounded-lg">
                            <div class="flex items-center gap-3">
                                <div class="w-8 h-8 rounded-lg bg-amber-100 flex items-center justify-center">
                                    <i data-lucide="mail" class="w-4 h-4 text-amber-600"></i>
                                </div>
                                <div>
                                    <p class="text-sm font-medium text-slate-700">Email Agent</p>
                                    <p class="text-xs text-slate-500">待发送队列: 23封</p>
                                </div>
                            </div>
