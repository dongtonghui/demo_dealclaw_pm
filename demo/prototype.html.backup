            </div>
        </aside>
    </div>
    
    <!-- JavaScript交互逻辑 -->
    <script>
        // 初始化图标
        lucide.createIcons();
        
        // 全局状态
        const state = {
            messages: [],
            tasks: [],
            leads: [],
            stats: {
                leads: 12,
                hot: 5,
                contacted: 48,
                responseRate: 23
            }
        };
        
        // 模拟数据生成
        const mockData = {
            companies: [
                { name: "OutdoorGear Pro", country: "美国", industry: "户外用品", size: "50-200人", revenue: "500万-1000万美元" },
                { name: "Summit Sports", country: "加拿大", industry: "运动装备", size: "200+人", revenue: "1000万+美元" },
                { name: "Alpine Adventures", country: "德国", industry: "户外零售", size: "10-50人", revenue: "100-500万美元" },
                { name: "TrailBlazer Inc", country: "英国", industry: "户外批发", size: "50-200人", revenue: "500万-1000万美元" },
                { name: "Camping World EU", country: "法国", industry: "露营用品", size: "200+人", revenue: "1000万+美元" }
            ],
            contacts: [
                { name: "Sarah Johnson", title: "采购总监", email: "sarah@outdoorgear.com", phone: "+1-555-0123" },
                { name: "Michael Chen", title: "CEO", email: "mchen@summitsports.com", phone: "+1-555-0456" },
                { name: "Emma Mueller", title: "采购经理", email: "emma@alpine.de", phone: "+49-555-0789" }
            ]
        };
        
        // 发送消息
        function sendMessage() {
            const input = document.getElementById('chat-input');
            const text = input.value.trim();
            if (!text) return;
            
            // 添加用户消息
            addUserMessage(text);
            input.value = '';
            input.style.height = 'auto';
            
            // 模拟AI思考并回复
            setTimeout(() => {
                processUserIntent(text);
            }, 800);
        }
        
        // 处理键盘事件
        function handleKeyDown(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
            // 自动调整高度
            const input = e.target;
            input.style.height = 'auto';
            input.style.height = Math.min(input.scrollHeight, 128) + 'px';
        }
        
        // 快速开始
        function quickStart(intent) {
            document.getElementById('chat-input').value = intent;
            sendMessage();
        }
        
        // 添加用户消息
        function addUserMessage(text) {
            const container = document.getElementById('chat-container');
            const html = `
                <div class="flex gap-4 fade-in justify-end">
                    <div class="flex-1 max-w-3xl">
                        <div class="bg-accent text-white rounded-2xl rounded-tr-sm p-5 shadow-sm message-bubble" style="margin-left: auto;">
                            <p class="leading-relaxed">${text}</p>
                        </div>
                    </div>
                    <div class="w-10 h-10 rounded-2xl bg-slate-200 flex items-center justify-center flex-shrink-0">
                        <i data-lucide="user" class="w-6 h-6 text-slate-600"></i>
                    </div>
                </div>
            `;
            container.insertAdjacentHTML('beforeend', html);
            lucide.createIcons();
            container.scrollTop = container.scrollHeight;
        }
        
        // 添加AI消息
        function addAIMessage(content, options = {}) {
            const container = document.getElementById('chat-container');
            const hasOptions = options.choices || options.card;
            
            let html = `
                <div class="flex gap-4 fade-in">
                    <div class="w-10 h-10 rounded-2xl agent-avatar flex items-center justify-center flex-shrink-0">
                        <i data-lucide="bot" class="w-6 h-6 text-white"></i>
                    </div>
                    <div class="flex-1 max-w-3xl">
                        <div class="bg-white rounded-2xl rounded-tl-sm p-5 shadow-sm border border-slate-100 message-bubble">
                            ${content}
                        </div>
            `;
            
            if (options.choices) {
                html += `<div class="flex gap-2 mt-3">`;
                options.choices.forEach(choice => {
                    html += `<button onclick="${choice.action}" class="px-4 py-2 bg-white border border-slate-200 rounded-full text-sm text-slate-600 hover:border-accent hover:text-accent transition-all">${choice.text}</button>`;
                });
                html += `</div>`;
            }
            
            html += `</div></div>`;
            container.insertAdjacentHTML('beforeend', html);
            lucide.createIcons();
            container.scrollTop = container.scrollHeight;
        }
        
        // 显示打字中
        function showTyping() {
            const container = document.getElementById('chat-container');
            const id = 'typing-' + Date.now();
            const html = `
                <div id="${id}" class="flex gap-4 fade-in">
                    <div class="w-10 h-10 rounded-2xl agent-avatar flex items-center justify-center flex-shrink-0">
                        <i data-lucide="bot" class="w-6 h-6 text-white"></i>
                    </div>
                    <div class="bg-white rounded-2xl rounded-tl-sm p-4 shadow-sm border border-slate-100 flex items-center gap-1">
                        <span class="w-2 h-2 bg-slate-400 rounded-full typing-dot"></span>
                        <span class="w-2 h-2 bg-slate-400 rounded-full typing-dot"></span>
                        <span class="w-2 h-2 bg-slate-400 rounded-full typing-dot"></span>
                    </div>
                </div>
            `;
            container.insertAdjacentHTML('beforeend', html);
            container.scrollTop = container.scrollHeight;
            return id;
        }
        
        // 移除打字中
        function removeTyping(id) {
            const el = document.getElementById(id);
            if (el) el.remove();
        }
        
        // 处理用户意图
        function processUserIntent(text) {
            const typingId = showTyping();
            
            setTimeout(() => {
                removeTyping(typingId);
                
                if (text.includes('户外') || text.includes('美国') || text.includes('批发商')) {
                    showProfileCard();
                } else if (text.includes('方案') || text.includes('渠道')) {
                    showStrategyCard();
                } else if (text.includes('线索') || text.includes('客户')) {
                    showLeadCard();
                } else {
                    addAIMessage(`收到！我来帮您分析需求并制定获客方案。请问您的目标客户是哪些地区或行业的？`, {
                        choices: [
                            { text: '🇺🇸 美国市场', action: 'quickStart("找美国户外用品批发商")' },
                            { text: '🇪🇺 欧洲市场', action: 'quickStart("找欧洲电子产品进口商")' },
                            { text: '🌍 其他市场', action: 'quickStart("帮我分析目标市场")' }
                        ]
                    });
                }
            }, 1500);
        }
        
        // 显示画像确认卡片
        function showProfileCard() {
            const container = document.getElementById('chat-container');
            const html = `
                <div class="flex gap-4 fade-in">
                    <div class="w-10 h-10 rounded-2xl agent-avatar flex items-center justify-center flex-shrink-0">
                        <i data-lucide="bot" class="w-6 h-6 text-white"></i>
                    </div>
                    <div class="flex-1 max-w-3xl">
                        <div class="mb-3 text-slate-600 text-sm">好的！我从您的描述中提取了以下客户画像，请确认：</div>
                        
                        <div class="rich-card rounded-2xl p-6">
                            <div class="flex items-center justify-between mb-5">
                                <div class="flex items-center gap-3">
                                    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center">
                                        <i data-lucide="users" class="w-6 h-6 text-white"></i>
                                    </div>
                                    <div>
                                        <h4 class="font-bold text-slate-800">目标客户画像</h4>
                                        <p class="text-xs text-slate-500">AI自动解析</p>
                                    </div>
                                </div>
                                <span class="px-3 py-1 bg-blue-100 text-blue-700 text-xs font-semibold rounded-full">置信度 92%</span>
                            </div>
                            
                            <div class="grid grid-cols-2 gap-4 mb-5">
                                <div class="p-3 bg-slate-50 rounded-xl">
                                    <div class="text-xs text-slate-500 mb-1">🌍 目标地区</div>
                                    <div class="font-semibold text-slate-800">美国</div>
                                </div>
                                <div class="p-3 bg-slate-50 rounded-xl">
                                    <div class="text-xs text-slate-500 mb-1">🏭 行业</div>
                                    <div class="font-semibold text-slate-800">户外用品批发</div>
                                </div>
                                <div class="p-3 bg-slate-50 rounded-xl">
                                    <div class="text-xs text-slate-500 mb-1">👥 公司规模</div>
                                    <div class="font-semibold text-slate-800">50-200人</div>
                                </div>
                                <div class="p-3 bg-slate-50 rounded-xl">
                                    <div class="text-xs text-slate-500 mb-1">💰 年采购额</div>
                                    <div class="font-semibold text-slate-800">100万-500万美元</div>
                                </div>
                            </div>
                            
                            <div class="flex gap-3">
                                <button onclick="confirmProfile()" class="flex-1 py-3 bg-accent hover:bg-accent/90 text-white rounded-xl font-medium transition-all flex items-center justify-center gap-2">
                                    <i data-lucide="check" class="w-4 h-4"></i>
                                    确认画像
                                </button>
                                <button class="px-4 py-3 border border-slate-200 text-slate-600 rounded-xl font-medium hover:bg-slate-50 transition-all">
                                    <i data-lucide="edit-2" class="w-4 h-4"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            container.insertAdjacentHTML('beforeend', html);
            lucide.createIcons();
            container.scrollTop = container.scrollHeight;
        }
        
        // 确认画像后显示渠道方案
        function confirmProfile() {
            addUserMessage('确认画像');
            setTimeout(() => {
                showStrategyCard();
            }, 500);
        }
        
        // 显示渠道方案卡片
        function showStrategyCard() {
            const container = document.getElementById('chat-container');
            const html = `
                <div class="flex gap-4 fade-in">
                    <div class="w-10 h-10 rounded-2xl agent-avatar flex items-center justify-center flex-shrink-0">
                        <i data-lucide="bot" class="w-6 h-6 text-white"></i>
                    </div>
                    <div class="flex-1 max-w-3xl">
                        <div class="mb-3 text-slate-600 text-sm">正在调用Agent团队制定获客方案...</div>
                        
                        <div class="rich-card rounded-2xl p-6">
                            <div class="flex items-center justify-between mb-5">
                                <div class="flex items-center gap-3">
                                    <div class="w-12 h-12 rounded-xl bg-gradient-to-br from-emerald-500 to-teal-600 flex items-center justify-center">
                                        <i data-lucide="zap" class="w-6 h-6 text-white"></i>
                                    </div>
                                    <div>
                                        <h4 class="font-bold text-slate-800">获客渠道方案</h4>
                                        <p class="text-xs text-slate-500">双引擎协同策略</p>
                                    </div>
                                </div>
                                <div class="text-right">
                                    <div class="text-xs text-slate-500">预期获客周期</div>
                                    <div class="font-bold text-emerald-600">4-6周</div>
                                </div>
                            </div>
                            
                            <!-- 核心引擎 -->
                            <div class="mb-4 p-4 bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-100 rounded-xl">
                                <div class="flex items-center gap-2 mb-3">
                                    <span class="px-2 py-1 bg-accent text-white text-xs font-bold rounded">核心引擎</span>
                                    <span class="text-sm font-semibold text-slate-800">数据驱动精准外联</span>
                                </div>
                                <div class="space-y-2 text-sm text-slate-600">
                                    <div class="flex items-center gap-2">
                                        <i data-lucide="check-circle" class="w-4 h-4 text-emerald-500"></i>
                                        从3亿+企业库匹配潜在客户
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <i data-lucide="check-circle" class="w-4 h-4 text-emerald-500"></i>
                                        海关数据交叉验证（筛选有进口记录的买家）
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <i data-lucide="check-circle" class="w-4 h-4 text-emerald-500"></i>
                                        AI挖掘决策人联系方式
                                    </div>
                                </div>
                            </div>
                            
                            <!-- 渠道组合 -->
                            <div class="space-y-3 mb-5">
                                <div class="flex items-center gap-4 p-3 bg-white border border-slate-200 rounded-xl">
                                    <div class="w-10 h-10 rounded-lg bg-amber-100 flex items-center justify-center">
                                        <i data-lucide="mail" class="w-5 h-5 text-amber-600"></i>
                                    </div>
                                    <div class="flex-1">
                                        <div class="font-semibold text-slate-800">邮件外联</div>
                                        <div class="text-xs text-slate-500">每日50封精准开发信</div>
                                    </div>
                                    <div class="text-right">
                                        <div class="text-sm font-bold text-slate-800">12条/月</div>
                                        <div class="text-xs text-emerald-600">预期线索</div>
                                    </div>
                                </div>
                                
                                <div class="flex items-center gap-4 p-3 bg-white border border-slate-200 rounded-xl">
                                    <div class="w-10 h-10 rounded-lg bg-pink-100 flex items-center justify-center">
                                        <i data-lucide="linkedin" class="w-5 h-5 text-pink-600"></i>
                                    </div>
                                    <div class="flex-1">
                                        <div class="font-semibold text-slate-800">LinkedIn社媒</div>
                                        <div class="text-xs text-slate-500">每周5篇专业内容+私信触达</div>
                                    </div>
                                    <div class="text-right">
                                        <div class="text-sm font-bold text-slate-800">5条/月</div>
                                        <div class="text-xs text-emerald-600">预期线索</div>
                                    </div>
                                </div>
                                
                                <div class="flex items-center gap-4 p-3 bg-white border border-slate-200 rounded-xl">
                                    <div class="w-10 h-10 rounded-lg bg-green-100 flex items-center justify-center">
                                        <i data-lucide="message-circle" class="w-5 h-5 text-green-600"></i>
                                    </div>
                                    <div class="flex-1">
                                        <div class="font-semibold text-slate-800">WhatsApp Business</div>
                                        <div class="text-xs text-slate-500">即时沟通快速转化</div>
                                    </div>
                                    <div class="text-right">
                                        <div class="text-sm font-bold text-slate-800">8条/月</div>
                                        <div class="text-xs text-emerald-600">预期线索</div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- 预期效果 -->
                            <div class="p-4 bg-slate-50 rounded-xl mb-5">
                                <div class="flex items-center justify-between mb-2">
                                    <span class="text-sm font-semibold text-slate-700">预期效果</span>
                                    <span class="text-xs text-slate-500">基于相似客户数据</span>
                                </div>
                                <div class="grid grid-cols-3 gap-4">
                                    <div class="text-center">
                                        <div class="text-2xl font-bold text-accent">25-40</div>
                                        <div class="text-xs text-slate-500">条/月线索</div>
                                    </div>
                                    <div class="text-center">
                                        <div class="text-2xl font-bold text-emerald-600">15-20%</div>
                                        <div class="text-xs text-slate-500">回复率</div>
                                    </div>
                                    <div class="text-center">
                                        <div class="text-2xl font-bold text-purple-600">¥150</div>
                                        <div class="text-xs text-slate-500">单条成本</div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="flex gap-3">
                                <button onclick="startTask()" class="flex-1 py-3 bg-accent hover:bg-accent/90 text-white rounded-xl font-medium transition-all flex items-center justify-center gap-2">
                                    <i data-lucide="play" class="w-4 h-4"></i>
                                    确认执行
                                </button>
                                <button class="px-4 py-3 border border-slate-200 text-slate-600 rounded-xl font-medium hover:bg-slate-50 transition-all">
                                    调整配置
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `;
            container.insertAdjacentHTML('beforeend', html);
            lucide.createIcons();
            container.scrollTop = container.scrollHeight;
        }
        
        // 开始任务
        function startTask() {
            addUserMessage('确认执行');
            setTimeout(() => {
                const container = document.getElementById('chat-container');
                const html = `
                    <div class="flex gap-4 fade-in">
                        <div class="w-10 h-10 rounded-2xl agent-avatar flex items-center justify-center flex-shrink-0">
                            <i data-lucide="bot" class="w-6 h-6 text-white"></i>
                        </div>
                        <div class="flex-1 max-w-3xl">
                            <div class="bg-white rounded-2xl rounded-tl-sm p-5 shadow-sm border border-slate-100 message-bubble">
                                <div class="flex items-center gap-3 mb-4">
                                    <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center">
                                        <i data-lucide="check" class="w-4 h-4 text-emerald-600"></i>
                                    </div>
                                    <span class="font-semibold text-slate-800">获客任务已启动！</span>
                                </div>
                                
                                <p class="text-slate-600 mb-4">各Agent正在协同工作：</p>
                                
                                <div class="space-y-3">
                                    <div class="flex items-center gap-3 p-3 bg-slate-50 rounded-lg">
                                        <div class="w-8 h-8 rounded-lg bg-indigo-100 flex items-center justify-center">
                                            <i data-lucide="search" class="w-4 h-4 text-indigo-600"></i>
                                        </div>
                                        <div class="flex-1">
                                            <p class="text-sm font-medium text-slate-700">数据外联Agent</p>
                                            <p class="text-xs text-slate-500">正在从企业库匹配潜在客户...</p>
                                        </div>
                                        <div class="typing-indicator flex gap-1">
                                            <span class="w-1.5 h-1.5 bg-indigo-400 rounded-full"></span>
                                            <span class="w-1.5 h-1.5 bg-indigo-400 rounded-full"></span>
                                            <span class="w-1.5 h-1.5 bg-indigo-400 rounded-full"></span>
                                        </div>
                                    </div>
                                    
                                    <div class="flex items-center gap-3 p-3 bg-slate-50 rounded-lg">
                                        <div class="w-8 h-8 rounded-lg bg-amber-100 flex items-center justify-center">
                                            <i data-lucide="mail" class="w-4 h-4 text-amber-600"></i>
                                        </div>
                                        <div class="flex-1">
                                            <p class="text-sm font-medium text-slate-700">Email Agent</p>
                                            <p class="text-xs text-slate-500">准备开发信模板队列</p>
                                        </div>
                                        <span class="text-xs text-slate-400">待启动</span>
                                    </div>
                                    
                                    <div class="flex items-center gap-3 p-3 bg-slate-50 rounded-lg">
                                        <div class="w-8 h-8 rounded-lg bg-pink-100 flex items-center justify-center">
                                            <i data-lucide="linkedin" class="w-4 h-4 text-pink-600"></i>
                                        </div>
                                        <div class="flex-1">
                                            <p class="text-sm font-medium text-slate-700">社媒Agent</p>
                                            <p class="text-xs text-slate-500">准备LinkedIn内容日历</p>
                                        </div>
                                        <span class="text-xs text-slate-400">待启动</span>
                                    </div>
                                </div>
                                
                                <div class="mt-4 p-3 bg-blue-50 rounded-lg border border-blue-100">
                                    <p class="text-sm text-blue-700">💡 我会每天18:00向您汇报任务进展和新线索。</p>
                                </div>
                            </div>
                        </div>
                    </div>
                `;
                container.insertAdjacentHTML('beforeend', html);
                lucide.createIcons();
                container.scrollTop = container.scrollHeight;
                
                // 更新右侧数据
                updateRightPanel();
            }, 500);
        }
        
        // 更新右侧面板数据
        function updateRightPanel() {
            // 更新统计数据
            animateNumber('stat-leads', 12, 18);
            animateNumber('stat-hot', 5, 8);
        }
        
        // 数字动画
        function animateNumber(id, from, to) {
            const el = document.getElementById(id);
            const duration = 1000;
            const start = performance.now();
            
            function update(now) {
                const elapsed = now - start;
                const progress = Math.min(elapsed / duration, 1);
                const value = Math.floor(from + (to - from) * progress);
                el.textContent = value;
                
                if (progress < 1) {
                    requestAnimationFrame(update);
                }
            }
            requestAnimationFrame(update);
        }
        
        // 切换视图
        function switchView(view) {
            // 更新导航状态
            document.querySelectorAll('.nav-item').forEach(el => {
                el.classList.remove('text-accent', 'bg-blue-50');
                el.classList.add('text-slate-600');
            });
            document.getElementById('nav-' + view).classList.add('text-accent', 'bg-blue-50');
            document.getElementById('nav-' + view).classList.remove('text-slate-600');
            
            // 这里可以切换不同视图的内容
            if (view === 'chat') {
                document.getElementById('main-chat').style.display = 'flex';
            }
        }
        
        // 显示数据面板
        function showDataPanel() {
            // 可以展开更详细的数据视图
            console.log('显示详细数据面板');
        }
        
        // 模拟实时数据更新
        setInterval(() => {
            // 随机更新线索数量
            const leadsEl = document.getElementById('stat-leads');
            const currentLeads = parseInt(leadsEl.textContent);
            if (Math.random() > 0.7) {
                leadsEl.textContent = currentLeads + 1;
            }
        }, 15000); // 每15秒可能更新一次
        
        // 初始化
        document.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();
            
            // 聚焦输入框
            document.getElementById('chat-input').focus();
        });
    </script>
</body>
</html>